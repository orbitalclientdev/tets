                hueBar.ZIndex = 4
                hueBar.Parent = pickerArea
                local hueCorner = Instance.new("UICorner"); hueCorner.CornerRadius = UDim.new(0, 4); hueCorner.Parent = hueBar
                local hueGrad = Instance.new("UIGradient")
                hueGrad.Color = ColorSequence.new{
                    ColorSequenceKeypoint.new(0, Color3.fromHSV(0,1,1)), ColorSequenceKeypoint.new(0.167, Color3.fromHSV(0.167,1,1)),
                    ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333,1,1)), ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5,1,1)),
                    ColorSequenceKeypoint.new(0.667, Color3.fromHSV(0.667,1,1)), ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833,1,1)),
                    ColorSequenceKeypoint.new(1, Color3.fromHSV(1,1,1))
                }
                hueGrad.Parent = hueBar

                -- SV box
                local svBox = Instance.new("Frame")
                svBox.Size = UDim2.new(1, 0, 0, 100)
                svBox.BackgroundColor3 = Color3.fromHSV(0, 1, 1)
                svBox.BorderSizePixel = 0
                svBox.ZIndex = 4
                svBox.Parent = pickerArea
                local svCorner = Instance.new("UICorner"); svCorner.CornerRadius = UDim.new(0, 6); svCorner.Parent = svBox

                -- White overlay (left to right)
                local whiteOv = Instance.new("UIGradient")
                whiteOv.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.new(1,1,1)), ColorSequenceKeypoint.new(1, Color3.new(1,1,1))}
                whiteOv.Transparency = NumberSequence.new{NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1)}
                whiteOv.Parent = svBox

                -- Black overlay frame on top
                local blackOv = Instance.new("Frame")
                blackOv.Size = UDim2.new(1, 0, 1, 0)
                blackOv.BackgroundColor3 = Color3.new(0, 0, 0)
                blackOv.BorderSizePixel = 0
                blackOv.ZIndex = 5
                blackOv.Parent = svBox
                local bCorner2 = Instance.new("UICorner"); bCorner2.CornerRadius = UDim.new(0, 6); bCorner2.Parent = blackOv
                local blackGrad = Instance.new("UIGradient")
                blackGrad.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.new(0,0,0)), ColorSequenceKeypoint.new(1, Color3.new(0,0,0))}
                blackGrad.Transparency = NumberSequence.new{NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0)}
                blackGrad.Rotation = 90
                blackGrad.Parent = blackOv

                local opened = false
                local h, s, v = Color3.toHSV(cpSettings.Color)
                local CPV = {Color = cpSettings.Color, Type = "ColorPicker", Settings = cpSettings}

                local function updateColor()
                    CPV.Color = Color3.fromHSV(h, s, v)
                    preview.BackgroundColor3 = CPV.Color
                    svBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                    SafeCall(nil, cpSettings.Name, cpSettings.Callback, CPV.Color)
                end

                -- Toggle open/close
                local headerBtn = Instance.new("TextButton"); headerBtn.Size = UDim2.new(1, 0, 0, 38); headerBtn.BackgroundTransparency = 1; headerBtn.Text = ""; headerBtn.ZIndex = 6; headerBtn.Parent = cp
                headerBtn.MouseButton1Click:Connect(function()
                    opened = not opened
                    tween(cp, {Size = UDim2.new(1, 0, 0, opened and 195 or 38)}, nil, TWEENINFO)
                end)

                -- SV interaction
                local svDragging = false
                local svInteract = MakeInteract(blackOv); svInteract.ZIndex = 7
                local function updateSV(input)
                    local pos = svBox.AbsolutePosition
                    local sz = svBox.AbsoluteSize
                    s = math.clamp((input.Position.X - pos.X) / sz.X, 0, 1)
                    v = 1 - math.clamp((input.Position.Y - pos.Y) / sz.Y, 0, 1)
                    updateColor()
                end
                svInteract.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then svDragging = true; updateSV(input) end end)
                svInteract.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then svDragging = false end end)

                -- Hue interaction
                local hueDragging = false
                local hueInteract = MakeInteract(hueBar); hueInteract.ZIndex = 7
                local function updateHue(input) h = math.clamp((input.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1); updateColor() end
                hueInteract.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then hueDragging = true; updateHue(input) end end)
                hueInteract.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then hueDragging = false end end)

                track(UserInputService.InputChanged:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseMovement then
                        if svDragging then updateSV(input) end
                        if hueDragging then updateHue(input) end
                    end
                end))

                cp.MouseEnter:Connect(function() tween(cp.UIStroke, {Color = COLORS.borderHover}, nil, TWEENINFO_FAST) end)
                cp.MouseLeave:Connect(function() tween(cp.UIStroke, {Color = COLORS.border}, nil, TWEENINFO_FAST) end)

                function CPV:Set(newSettings) if newSettings.Color then h, s, v = Color3.toHSV(newSettings.Color); updateColor() end end
                function CPV:Destroy() cp:Destroy() end
                if cpSettings.Flag then Library.Flags[cpSettings.Flag] = CPV; Library.Options[cpSettings.Flag] = CPV end
                return CPV
            end

            return Section
        end -- end CreateSection

        -- Shortcut methods directly on Tab (auto-creates a default section)
        local defaultSection
        local function getDefaultSection()
            if not defaultSection then defaultSection = Tab:CreateSection("") end
            return defaultSection
        end

        for _, method in ipairs({"CreateButton", "CreateLabel", "CreateParagraph", "CreateToggle", "CreateSlider", "CreateDivider", "CreateDropdown", "CreateInput", "CreateBind", "CreateKeybind", "CreateColorPicker"}) do
            Tab[method] = function(self, ...) return getDefaultSection()[method](getDefaultSection(), ...) end
        end

        -- Config section builder
        function Tab:BuildConfigSection()
            local configSection = Tab:CreateSection("Configuration")
            configSection:CreateLabel({Text = "Configuration saving is handled via flags.", Style = 2})
            return configSection
        end

        -- Theme section builder
        function Tab:BuildThemeSection()
            local themeSection = Tab:CreateSection("Theme")
            local presetNames = {}
            for name, _ in pairs(GradientPresets) do table.insert(presetNames, name) end
            table.sort(presetNames)

            themeSection:CreateDropdown({
                Name = "Theme Preset",
                Options = presetNames,
                CurrentOption = settings.Theme,
                MultipleOptions = false,
                Callback = function(selected)
                    local colors = GradientPresets[selected]
                    if colors then
                        Library.ThemeGradient = MakeGradientSequence(colors)
                        gradient.Color = Library.ThemeGradient
                    end
                end
            })
            return themeSection
        end

        return Tab
    end -- end CreateTab

    -- Config Save/Load
    function Window:SaveConfiguration()
        if not settings.ConfigurationSaving or not settings.ConfigurationSaving.Enabled then return end
        local data = {}
        for flagName, flag in pairs(Library.Flags) do
            if flag.Type == "ColorPicker" then
                data[flagName] = PackColor(flag.Color)
            elseif flag.Type == "Dropdown" then
                data[flagName] = flag.CurrentOption
            elseif flag.Type == "Toggle" then
                data[flagName] = flag.CurrentValue
            elseif flag.Type == "Slider" then
                data[flagName] = flag.CurrentValue
            elseif flag.Type == "Input" then
                data[flagName] = flag.CurrentValue
            elseif flag.Type == "Keybind" then
                data[flagName] = flag.CurrentBind
            end
        end
        pcall(function()
            local folder = settings.ConfigurationSaving.FolderName or "5BLib"
            local file = settings.ConfigurationSaving.FileName or "config"
            if isfolder and not isfolder(folder) then makefolder(folder) end
            writefile(folder .. "/" .. file .. ".json", HttpService:JSONEncode(data))
        end)
    end

    function Window:LoadConfiguration()
        if not settings.ConfigurationSaving or not settings.ConfigurationSaving.Enabled then return end
        pcall(function()
            local folder = settings.ConfigurationSaving.FolderName or "5BLib"
            local file = settings.ConfigurationSaving.FileName or "config"
            local path = folder .. "/" .. file .. ".json"
            if isfile and isfile(path) then
                local data = HttpService:JSONDecode(readfile(path))
                for flagName, value in pairs(data) do
                    local flag = Library.Flags[flagName]
                    if flag then
                        if flag.Type == "ColorPicker" then
                            flag:Set({Color = UnpackColor(value)})
                        elseif flag.Type == "Dropdown" then
                            flag:Set(value)
                        else
                            flag:Set(value)
                        end
                    end
                end
                Library:Notification({Title = "Config Loaded", Content = "Configuration loaded successfully.", Icon = "save", Type = "Success"})
            end
        end)
    end

    return Window
end -- end CreateWindow

function Library:Destroy()
    for _, conn in ipairs(connections) do
        pcall(function() conn:Disconnect() end)
    end
    connections = {}
    if self._notifContainer and self._notifContainer.Parent then
        self._notifContainer.Parent:Destroy()
    end
    Library.Flags = {}
    Library.Options = {}
end

return Library
