-- Utilities
local function tween(obj, props, callback, info)
    local t = TweenService:Create(obj, info or TWEENINFO, props)
    if callback then t.Completed:Connect(callback) end
    t:Play()
    return t
end

local function Kwargify(defaults, passed)
    for i, v in pairs(defaults) do
        if passed[i] == nil then passed[i] = v end
    end
    return passed
end

local function PackColor(c)
    return {R = c.R * 255, G = c.G * 255, B = c.B * 255}
end

local function UnpackColor(c)
    return Color3.fromRGB(c.R, c.G, c.B)
end

local function GetIcon(name)
    if not name then return "" end
    if string.find(name, "rbxassetid") then return name end
    if tonumber(name) then return "rbxassetid://" .. name end
    return MaterialIcons[name] or MaterialIcons["view_in_ar"]
end

local function MakeGradientSequence(colors)
    local keypoints = {}
    for i, c in ipairs(colors) do
        table.insert(keypoints, ColorSequenceKeypoint.new((i - 1) / (#colors - 1), c))
    end
    return ColorSequence.new(keypoints)
end

-- Glassmorphism Frame Builder
local function MakeGlassFrame(props)
    props = Kwargify({
        Name = "GlassFrame",
        Size = UDim2.new(1, 0, 0, 40),
        Position = UDim2.new(0, 0, 0, 0),
        AnchorPoint = Vector2.new(0, 0),
        Parent = nil,
        BgColor = COLORS.bgElement,
        BgTransparency = 0.5,
        BorderColor = COLORS.border,
        BorderTransparency = 0.5,
        CornerRadius = UDim.new(0, 8),
        LayoutOrder = 0,
        ZIndex = 1,
        Visible = true,
    }, props or {})

    local frame = Instance.new("Frame")
    frame.Name = props.Name
    frame.Size = props.Size
    frame.Position = props.Position
    frame.AnchorPoint = props.AnchorPoint
    frame.BackgroundColor3 = props.BgColor
    frame.BackgroundTransparency = props.BgTransparency
    frame.BorderSizePixel = 0
    frame.LayoutOrder = props.LayoutOrder
    frame.ZIndex = props.ZIndex
    frame.Visible = props.Visible

    local corner = Instance.new("UICorner")
    corner.CornerRadius = props.CornerRadius
    corner.Parent = frame

    local stroke = Instance.new("UIStroke")
    stroke.Color = props.BorderColor
    stroke.Transparency = props.BorderTransparency
    stroke.Thickness = 1
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = frame

    if props.Parent then frame.Parent = props.Parent end
    return frame, stroke, corner
end

