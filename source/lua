		-- ГўвЂўВђГўвЂўВђГўвЂўВђ COLOR PICKER ГўвЂўВђГўвЂўВђГўвЂўВђ
		function Tab:CreateColorPicker(cfg)
			cfg = cfg or {}; cfg.Type = "ColorPicker"; cfg.Color = cfg.Color or Color3.fromRGB(255,255,255)
			local h,s,v = cfg.Color:ToHSV(); local opened = false

			local f = mk("Frame", {Name=cfg.Name or "ColorPicker", BackgroundColor3=T.Surface, Size=UDim2.new(1,0,0,38), ClipsDescendants=true, Parent=page})
			corner(f, CRs); stroke(f)
			mk("TextLabel", {BackgroundTransparency=1, Position=UDim2.new(0,12,0,0), Size=UDim2.new(1,-65,0,38), Font=Enum.Font.Gotham, Text=cfg.Name or "Color", TextColor3=T.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, Parent=f})

			local preview = mk("Frame", {BackgroundColor3=cfg.Color, AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,-12,0,19), Size=UDim2.new(0,32,0,20), Parent=f})
			corner(preview, CRs); stroke(preview, T.Border)

			-- HSV area
			local cpMain = mk("ImageLabel", {Name="CP", BackgroundColor3=Color3.fromHSV(h,1,1), Image="http://www.roblox.com/asset/?id=11415645739", Position=UDim2.new(0,12,0,46), Size=UDim2.new(1,-80,0,80), Parent=f})
			corner(cpMain, CRs)
			local cpPoint = mk("ImageLabel", {BackgroundTransparency=1, Image="rbxassetid://6031091004", ImageColor3=Color3.fromHSV(h,s,v), AnchorPoint=Vector2.new(0.5,0.5), Position=UDim2.new(s,0,1-v,0), Size=UDim2.new(0,16,0,16), Parent=cpMain})

			-- Hue slider
			local hueBar = mk("ImageLabel", {BackgroundColor3=Color3.new(1,1,1), Image="rbxassetid://11415645739", Position=UDim2.new(1,-56,0,46), Size=UDim2.new(0,28,0,80), Parent=f})
			corner(hueBar, CRs)
			-- rainbow gradient
			local hueGrad = mk("UIGradient", {Rotation=90, Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromHSV(0,1,1)), ColorSequenceKeypoint.new(0.17,Color3.fromHSV(0.17,1,1)), ColorSequenceKeypoint.new(0.33,Color3.fromHSV(0.33,1,1)), ColorSequenceKeypoint.new(0.5,Color3.fromHSV(0.5,1,1)), ColorSequenceKeypoint.new(0.67,Color3.fromHSV(0.67,1,1)), ColorSequenceKeypoint.new(0.83,Color3.fromHSV(0.83,1,1)), ColorSequenceKeypoint.new(1,Color3.fromHSV(1,1,1))}), Parent=hueBar})
			local huePoint = mk("Frame", {BackgroundColor3=T.Text, AnchorPoint=Vector2.new(0.5,0.5), Position=UDim2.new(0.5,0,h,0), Size=UDim2.new(1,4,0,4), Parent=hueBar})
			corner(huePoint, UDim.new(1,0))

			-- Hex input
			local hexBox = mk("TextBox", {BackgroundColor3=T.InputBg, Position=UDim2.new(0,12,0,134), Size=UDim2.new(1,-24,0,24), Font=Enum.Font.GothamBold, Text=string.format("#%02X%02X%02X",cfg.Color.R*255,cfg.Color.G*255,cfg.Color.B*255), TextColor3=T.Text, TextSize=12, ClearTextOnFocus=false, Parent=f})
			corner(hexBox, CRs)

			local mainDrag, hueDrag = false, false

			local function applyColor()
				local c = Color3.fromHSV(h,s,v); cfg.Color = c; preview.BackgroundColor3 = c; cpMain.BackgroundColor3 = Color3.fromHSV(h,1,1)
				cpPoint.Position = UDim2.new(s,0,1-v,0); cpPoint.ImageColor3 = c; huePoint.Position = UDim2.new(0.5,0,h,0)
				hexBox.Text = string.format("#%02X%02X%02X", c.R*255, c.G*255, c.B*255)
				safecall(cfg.Callback, c); SaveConfiguration()
			end

			local headerBtn = mk("TextButton", {BackgroundTransparency=1, Size=UDim2.new(1,0,0,38), Text="", Parent=f})
			headerBtn.MouseButton1Click:Connect(function()
				opened = not opened
				tw(f, {Size=UDim2.new(1,0,0,opened and 166 or 38)}, 0.3)
			end)

			cpMain.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then mainDrag=true end end)
			hueBar.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then hueDrag=true end end)
			UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then mainDrag=false; hueDrag=false end end)

			table.insert(lib._connections, RunService.RenderStepped:Connect(function()
				if mainDrag then
					s = math.clamp((Mouse.X-cpMain.AbsolutePosition.X)/cpMain.AbsoluteSize.X,0,1)
					v = 1-math.clamp((Mouse.Y-cpMain.AbsolutePosition.Y)/cpMain.AbsoluteSize.Y,0,1)
					applyColor()
				elseif hueDrag then
					h = math.clamp((Mouse.Y-hueBar.AbsolutePosition.Y)/hueBar.AbsoluteSize.Y,0,1)
					applyColor()
				end
			end))

			hexBox.FocusLost:Connect(function()
				pcall(function()
					local r,g,b = string.match(hexBox.Text, "^#?(%x%x)(%x%x)(%x%x)$")
					local c = Color3.fromRGB(tonumber(r,16),tonumber(g,16),tonumber(b,16))
					h,s,v = c:ToHSV(); applyColor()
				end)
			end)

			f.MouseEnter:Connect(function() if not opened then tw(f, {BackgroundColor3=T.SurfaceHover}, 0.15) end end)
			f.MouseLeave:Connect(function() tw(f, {BackgroundColor3=T.Surface}, 0.15) end)

			function cfg:Set(c) h,s,v=c:ToHSV(); applyColor() end
			if configEnabled and cfg.Flag then lib.Flags[cfg.Flag] = cfg end
			return cfg
		end

		return Tab
	end

	-- ГўвЂўВђГўвЂўВђГўвЂўВђ LOAD CONFIG ГўвЂўВђГўвЂўВђГўвЂўВђ
	function lib:LoadConfiguration()
		if not configEnabled then return end
		pcall(function()
			if isfile and isfile(configFolderPath.."/"..configFile..".json") then
				local raw = readfile(configFolderPath.."/"..configFile..".json")
				local data = HttpService:JSONDecode(raw)
				for flag, val in pairs(data) do
					if lib.Flags[flag] then
						task.spawn(function()
							if lib.Flags[flag].Type == "ColorPicker" then
								lib.Flags[flag]:Set(Color3.fromRGB(val.R, val.G, val.B))
							else
								lib.Flags[flag]:Set(val)
							end
						end)
					end
				end
			end
		end)
	end

	-- ГўвЂўВђГўвЂўВђГўвЂўВђ DESTROY ГўвЂўВђГўвЂўВђГўвЂўВђ
	function lib:Destroy()
		lib._destroyed = true
		for _,c in ipairs(lib._connections) do pcall(function() c:Disconnect() end) end
		if lib.gui then lib.gui:Destroy() end
	end

	return Window, lib
end

return Library
