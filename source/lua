            -- SLIDER
            function Section:CreateSlider(sSettings)
                sSettings = Kwargify({Name = "Slider", Range = {0, 100}, Increment = 1, CurrentValue = 50, Suffix = "", Flag = nil, Callback = function() end}, sSettings or {})
                local slider = MakeGlassFrame({Name = sSettings.Name, Size = UDim2.new(1, 0, 0, 50), BgTransparency = 0.5, Parent = sectionContainer})
                local valLabel = MakeText({Name = "Value", Text = tostring(sSettings.CurrentValue) .. sSettings.Suffix, Size = UDim2.new(0, 80, 0, 16), Position = UDim2.new(1, -12, 0, 8), AnchorPoint = Vector2.new(1, 0), Font = Enum.Font.GothamSemibold, TextSize = 12, TextColor = accentColor, TextXAlignment = Enum.TextXAlignment.Right, Parent = slider, ZIndex = 3})
                MakeText({Text = sSettings.Name, Size = UDim2.new(1, -100, 0, 16), Position = UDim2.new(0, 12, 0, 8), Font = Enum.Font.GothamSemibold, TextSize = 13, Parent = slider, ZIndex = 3})

                -- Slider bar
                local bar = Instance.new("Frame"); bar.Name = "Bar"; bar.Size = UDim2.new(1, -24, 0, 6); bar.Position = UDim2.new(0, 12, 0, 34); bar.BackgroundColor3 = COLORS.toggleOff; bar.BorderSizePixel = 0; bar.ZIndex = 3; bar.Parent = slider
                local barCorner = Instance.new("UICorner"); barCorner.CornerRadius = UDim.new(1, 0); barCorner.Parent = bar
                local fill = Instance.new("Frame"); fill.Name = "Fill"; fill.Size = UDim2.new(0, 0, 1, 0); fill.BackgroundColor3 = accentColor; fill.BorderSizePixel = 0; fill.ZIndex = 4; fill.Parent = bar
                local fillCorner = Instance.new("UICorner"); fillCorner.CornerRadius = UDim.new(1, 0); fillCorner.Parent = fill

                local SliderV = {CurrentValue = sSettings.CurrentValue, Type = "Slider", Settings = sSettings}
                local min, max, inc = sSettings.Range[1], sSettings.Range[2], sSettings.Increment

                local function setValue(val)
                    val = math.clamp(val, min, max)
                    val = math.floor(val / inc + 0.5) * inc
                    val = tonumber(string.format("%.10g", val))
                    SliderV.CurrentValue = val
                    valLabel.Text = tostring(val) .. sSettings.Suffix
                    local pct = (val - min) / (max - min)
                    tween(fill, {Size = UDim2.new(pct, 0, 1, 0)}, nil, TWEENINFO_FAST)
                end
                setValue(sSettings.CurrentValue)

                -- Interaction
                local dragging = false
                local interact = MakeInteract(bar)
                interact.ZIndex = 5

                local function updateFromInput(input)
                    local barPos = bar.AbsolutePosition.X
                    local barSize = bar.AbsoluteSize.X
                    local rel = math.clamp((input.Position.X - barPos) / barSize, 0, 1)
                    local val = min + (max - min) * rel
                    setValue(val)
                    SafeCall(nil, sSettings.Name, sSettings.Callback, SliderV.CurrentValue)
                end

                interact.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        updateFromInput(input)
                    end
                end)
                interact.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
                end)
                track(UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        updateFromInput(input)
                    end
                end))

                slider.MouseEnter:Connect(function() tween(slider.UIStroke, {Color = COLORS.borderHover}, nil, TWEENINFO_FAST) end)
                slider.MouseLeave:Connect(function() tween(slider.UIStroke, {Color = COLORS.border}, nil, TWEENINFO_FAST) end)

                function SliderV:Set(val) setValue(val) SafeCall(nil, sSettings.Name, sSettings.Callback, SliderV.CurrentValue) end
                function SliderV:Destroy() slider:Destroy() end
                if sSettings.Flag then Library.Flags[sSettings.Flag] = SliderV; Library.Options[sSettings.Flag] = SliderV end
                return SliderV
            end

            -- DROPDOWN
            function Section:CreateDropdown(dSettings)
                dSettings = Kwargify({Name = "Dropdown", Description = nil, Options = {"Option 1", "Option 2"}, CurrentOption = nil, MultipleOptions = false, SpecialType = nil, Flag = nil, Callback = function() end}, dSettings or {})
                if dSettings.SpecialType == "Player" then
                    dSettings.Options = {}
                    for _, p in ipairs(Players:GetPlayers()) do table.insert(dSettings.Options, p.Name) end
                    dSettings.CurrentOption = dSettings.CurrentOption or (dSettings.Options[1] and {dSettings.Options[1]} or {})
                end
                if type(dSettings.CurrentOption) == "string" then dSettings.CurrentOption = {dSettings.CurrentOption} end
                dSettings.CurrentOption = dSettings.CurrentOption or {dSettings.Options[1] or ""}

                local closedH = dSettings.Description and 52 or 38
                local dd = MakeGlassFrame({Name = dSettings.Name, Size = UDim2.new(1, 0, 0, closedH), BgTransparency = 0.5, Parent = sectionContainer})
                dd.ClipsDescendants = true
                MakeText({Text = dSettings.Name, Size = UDim2.new(1, -70, 0, 16), Position = UDim2.new(0, 12, 0, dSettings.Description and 6 or 11), Font = Enum.Font.GothamSemibold, TextSize = 13, Parent = dd, ZIndex = 3})
                if dSettings.Description then MakeText({Text = dSettings.Description, Size = UDim2.new(1, -70, 0, 14), Position = UDim2.new(0, 12, 0, 24), Font = Enum.Font.Gotham, TextSize = 11, TextColor = COLORS.textMuted, Parent = dd, ZIndex = 3}) end

                -- Arrow icon
                local arrow = MakeIcon({Image = "expand_more", Size = UDim2.new(0, 18, 0, 18), Position = UDim2.new(1, -30, 0, dSettings.Description and 10 or 10), ImageColor = COLORS.textDim, Parent = dd, ZIndex = 4})

                -- Selected text
                local selText = MakeText({Name = "Selected", Text = table.concat(dSettings.CurrentOption, ", "), Size = UDim2.new(0, 120, 0, 14), Position = UDim2.new(1, -52, 0, dSettings.Description and 10 or 12), AnchorPoint = Vector2.new(1, 0), Font = Enum.Font.Gotham, TextSize = 11, TextColor = COLORS.textMuted, TextXAlignment = Enum.TextXAlignment.Right, Parent = dd, ZIndex = 3})

                -- Options list
                local optList = Instance.new("Frame")
                optList.Name = "Options"
                optList.Size = UDim2.new(1, -16, 0, 0)
                optList.Position = UDim2.new(0, 8, 0, closedH + 2)
                optList.BackgroundTransparency = 1
                optList.AutomaticSize = Enum.AutomaticSize.Y
                optList.ZIndex = 3
                optList.Parent = dd
                local optLayout = Instance.new("UIListLayout"); optLayout.Padding = UDim.new(0, 2); optLayout.Parent = optList

                local opened = false
                local selectedOptions = {}
                for _, o in ipairs(dSettings.CurrentOption) do selectedOptions[o] = true end

                local function refreshOptions()
                    for _, c in ipairs(optList:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
                    for _, optName in ipairs(dSettings.Options) do
                        local optFrame = MakeGlassFrame({Name = optName, Size = UDim2.new(1, 0, 0, 28), BgColor = selectedOptions[optName] and COLORS.bgLight or COLORS.bgElement, BgTransparency = selectedOptions[optName] and 0.3 or 0.7, BorderTransparency = 0.8, CornerRadius = UDim.new(0, 6), Parent = optList})
                        MakeText({Text = optName, Size = UDim2.new(1, -16, 1, 0), Position = UDim2.new(0, 8, 0, 0), Font = Enum.Font.Gotham, TextSize = 12, TextColor = selectedOptions[optName] and COLORS.text or COLORS.textDim, Parent = optFrame, ZIndex = 4})
                        local optInteract = MakeInteract(optFrame)
                        optInteract.MouseButton1Click:Connect(function()
                            if dSettings.MultipleOptions then
                                selectedOptions[optName] = not selectedOptions[optName]
                            else
                                selectedOptions = {}
                                selectedOptions[optName] = true
                                opened = false
                                tween(arrow, {Rotation = 0})
                                tween(dd, {Size = UDim2.new(1, 0, 0, closedH)}, nil, TWEENINFO)
                            end
                            local sel = {}
                            for _, o in ipairs(dSettings.Options) do if selectedOptions[o] then table.insert(sel, o) end end
                            dSettings.CurrentOption = sel
                            selText.Text = #sel > 0 and table.concat(sel, ", ") or "None"
                            refreshOptions()
                            SafeCall(dd, dSettings.Name, dSettings.Callback, dSettings.MultipleOptions and sel or (sel[1] or ""))
                        end)
                    end
                end
                refreshOptions()

                local headerInteract = Instance.new("TextButton")
                headerInteract.Size = UDim2.new(1, 0, 0, closedH)
                headerInteract.BackgroundTransparency = 1
                headerInteract.Text = ""
                headerInteract.ZIndex = 5
                headerInteract.Parent = dd
                headerInteract.MouseButton1Click:Connect(function()
                    opened = not opened
                    if opened then
                        local totalH = closedH + 4 + #dSettings.Options * 30
                        tween(arrow, {Rotation = 180})
                        tween(dd, {Size = UDim2.new(1, 0, 0, math.min(totalH, closedH + 160))}, nil, TWEENINFO)
                    else
                        tween(arrow, {Rotation = 0})
                        tween(dd, {Size = UDim2.new(1, 0, 0, closedH)}, nil, TWEENINFO)
                    end
                end)

                dd.MouseEnter:Connect(function() tween(dd.UIStroke, {Color = COLORS.borderHover}, nil, TWEENINFO_FAST) end)
                dd.MouseLeave:Connect(function() tween(dd.UIStroke, {Color = COLORS.border}, nil, TWEENINFO_FAST) end)

                local DDV = {CurrentOption = dSettings.CurrentOption, Type = "Dropdown", Settings = dSettings}
                function DDV:Set(opts) if type(opts) == "table" then dSettings.CurrentOption = opts else dSettings.CurrentOption = {opts} end; selectedOptions = {}; for _, o in ipairs(dSettings.CurrentOption) do selectedOptions[o] = true end; selText.Text = table.concat(dSettings.CurrentOption, ", "); refreshOptions() end
                function DDV:Refresh(newOpts) dSettings.Options = newOpts; refreshOptions() end
                function DDV:Destroy() dd:Destroy() end
                if dSettings.Flag then Library.Flags[dSettings.Flag] = DDV; Library.Options[dSettings.Flag] = DDV end
                return DDV
            end

