-- ГўвЂўВђГўвЂўВђГўвЂўВђ UTILITIES ГўвЂўВђГўвЂўВђГўвЂўВђ
local T = Themes.Default
local CR = UDim.new(0, 8)
local CRs = UDim.new(0, 6)

local function tw(obj, props, dur, style, dir)
	local t = TweenService:Create(obj, TweenInfo.new(dur or 0.25, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out), props)
	t:Play(); return t
end

local function mk(class, props)
	local i = Instance.new(class)
	for k,v in pairs(props or {}) do i[k] = v end
	return i
end

local function corner(p, r) return mk("UICorner", {CornerRadius = r or CR, Parent = p}) end
local function stroke(p, c, t) return mk("UIStroke", {Color = c or T.Border, Thickness = t or 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border, Parent = p}) end
local function pad(p, t, b, l, r) return mk("UIPadding", {PaddingTop=t or UDim.new(0,8), PaddingBottom=b or t or UDim.new(0,8), PaddingLeft=l or UDim.new(0,12), PaddingRight=r or l or UDim.new(0,12), Parent=p}) end
local function layout(p, padding, dir) return mk("UIListLayout", {SortOrder=Enum.SortOrder.LayoutOrder, Padding=UDim.new(0,padding or 6), FillDirection=dir or Enum.FillDirection.Vertical, Parent=p}) end

local function shadow(p)
	return mk("ImageLabel", {Name="Shadow", BackgroundTransparency=1, Image="rbxassetid://6014261993", ImageColor3=T.Shadow, ImageTransparency=0.5, Position=UDim2.new(0,-15,0,-15), Size=UDim2.new(1,30,1,30), ScaleType=Enum.ScaleType.Slice, SliceCenter=Rect.new(49,49,450,450), ZIndex=-1, Parent=p})
end

local function safecall(f, ...) if f then local ok,r = pcall(f, ...) if not ok then warn("5BLib Callback Error:", r) end return ok,r end end

-- ГўвЂўВђГўвЂўВђГўвЂўВђ LIBRARY ГўвЂўВђГўвЂўВђГўвЂўВђ
local Library = {Flags = {}, Theme = Themes}
Library.__index = Library

function Library:SetTheme(theme)
	if type(theme) == "string" then T = Themes[theme] or Themes.Default
	elseif type(theme) == "table" then T = theme end
end

function Library:CreateWindow(cfg)
	cfg = cfg or {}
	local lib = setmetatable({}, Library)
	lib.Flags = Library.Flags
	lib._connections = {}
	lib._destroyed = false

	if cfg.Theme then
		if type(cfg.Theme) == "string" then T = Themes[cfg.Theme] or Themes.Default
		elseif type(cfg.Theme) == "table" then T = cfg.Theme end
	end

	-- Config
	local configFolder = "5BLib"
	local configFile = cfg.ConfigurationSaving and cfg.ConfigurationSaving.FileName or tostring(game.PlaceId)
	local configEnabled = cfg.ConfigurationSaving and cfg.ConfigurationSaving.Enabled or false
	local configFolderPath = cfg.ConfigurationSaving and cfg.ConfigurationSaving.FolderName or (configFolder.."/Configs")

	local function ensureFolder(path)
		if isfolder and not pcall(isfolder, path) == false then
			if not isfolder(path) then pcall(makefolder, path) end
		end
	end

	if configEnabled then
		pcall(ensureFolder, configFolder)
		pcall(ensureFolder, configFolderPath)
	end

	-- ScreenGui
	lib.gui = mk("ScreenGui", {Name="5BLib", ZIndexBehavior=Enum.ZIndexBehavior.Sibling, ResetOnSpawn=false, DisplayOrder=100})
	pcall(function() lib.gui.Parent = game:GetService("CoreGui") end)
	if not lib.gui.Parent then lib.gui.Parent = Player:WaitForChild("PlayerGui") end

	-- Notifications
	lib.notifHolder = mk("Frame", {Name="Notifs", BackgroundTransparency=1, AnchorPoint=Vector2.new(1,1), Position=UDim2.new(1,-20,1,-20), Size=UDim2.new(0,320,1,-40), Parent=lib.gui})
	layout(lib.notifHolder, 8).VerticalAlignment = Enum.VerticalAlignment.Bottom

	-- Main Window
	local winW, winH = 540, 420
	local main = mk("Frame", {Name="Main", BackgroundColor3=T.Background, AnchorPoint=Vector2.new(0.5,0.5), Position=UDim2.new(0.5,0,0.5,0), Size=UDim2.new(0,winW,0,winH), ClipsDescendants=true, Parent=lib.gui})
	corner(main); stroke(main); shadow(main)
	lib.main = main

	-- Topbar
	local topbar = mk("Frame", {Name="Topbar", BackgroundColor3=T.Topbar, Size=UDim2.new(1,0,0,42), BorderSizePixel=0, Parent=main})
	corner(topbar)
	mk("Frame", {BackgroundColor3=T.Topbar, Position=UDim2.new(0,0,1,-8), Size=UDim2.new(1,0,0,8), BorderSizePixel=0, Parent=topbar})

	local titleLbl = mk("TextLabel", {BackgroundTransparency=1, Position=UDim2.new(0,16,0,0), Size=UDim2.new(1,-120,1,0), Font=Enum.Font.GothamBold, Text=cfg.Name or "5BLib", TextColor3=T.Text, TextSize=16, TextXAlignment=Enum.TextXAlignment.Left, Parent=topbar})

	-- Window buttons
	local function topBtn(text, pos, hoverColor)
		local b = mk("TextButton", {BackgroundTransparency=1, Position=pos, Size=UDim2.new(0,30,0,30), Font=Enum.Font.GothamBold, Text=text, TextColor3=T.TextDim, TextSize=18, Parent=topbar})
		b.MouseEnter:Connect(function() tw(b, {TextColor3=hoverColor}, 0.15) end)
		b.MouseLeave:Connect(function() tw(b, {TextColor3=T.TextDim}, 0.15) end)
		return b
	end

	local closeBtn = topBtn("ГѓвЂ”", UDim2.new(1,-38,0,6), T.Error)
	local minBtn = topBtn("Гўв‚¬вЂњ", UDim2.new(1,-68,0,6), T.Warning)
	local hideBtn = topBtn("ГўвЂ”вЂЎ", UDim2.new(1,-98,0,6), T.Accent)

	-- States
	local minimized, hidden = false, false
	local toggled = true
	local toggleKey = Enum.KeyCode.RightControl

	closeBtn.MouseButton1Click:Connect(function()
		tw(main, {Size=UDim2.new(0,winW,0,0), BackgroundTransparency=1}, 0.4)
		task.wait(0.45); main.Visible = false
	end)

	minBtn.MouseButton1Click:Connect(function()
		minimized = not minimized
		if minimized then
			tw(main, {Size=UDim2.new(0,winW,0,42)}, 0.35)
		else
			tw(main, {Size=UDim2.new(0,winW,0,winH)}, 0.35)
		end
	end)

	hideBtn.MouseButton1Click:Connect(function()
		hidden = true
		tw(main, {Size=UDim2.new(0,winW,0,0), BackgroundTransparency=1}, 0.4)
		task.wait(0.45); main.Visible = false
		lib:Notify({Title="UI Hidden", Content="Press "..toggleKey.Name.." to show the interface.", Duration=5})
	end)

	-- Toggle keybind
	table.insert(lib._connections, UserInputService.InputBegan:Connect(function(input, gpe)
		if gpe or lib._destroyed then return end
		if input.KeyCode == toggleKey then
			if hidden then
				hidden = false; minimized = false
				main.Visible = true
				main.BackgroundTransparency = 0
				tw(main, {Size=UDim2.new(0,winW,0,winH)}, 0.4)
			else
				toggled = not toggled
				lib.gui.Enabled = toggled
			end
		end
	end))

	-- Dragging
	local dragging,dragStart,startPos
	topbar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging=true; dragStart=input.Position; startPos=main.Position
		end
	end)
	topbar.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging=false end
	end)
	table.insert(lib._connections, UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local d = input.Position - dragStart
			tw(main, {Position=UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X, startPos.Y.Scale, startPos.Y.Offset+d.Y)}, 0.08)
		end
	end))

	-- Divider under topbar
	mk("Frame", {BackgroundColor3=T.Border, Position=UDim2.new(0,0,0,42), Size=UDim2.new(1,0,0,1), BorderSizePixel=0, Parent=main})

	-- Tab sidebar
	local sideW = 150
	local sidebar = mk("Frame", {Name="Sidebar", BackgroundColor3=T.Topbar, Position=UDim2.new(0,0,0,43), Size=UDim2.new(0,sideW,1,-43), BorderSizePixel=0, Parent=main})
	corner(sidebar)
	mk("Frame", {BackgroundColor3=T.Topbar, Size=UDim2.new(1,0,0,8), BorderSizePixel=0, Parent=sidebar})
	mk("Frame", {BackgroundColor3=T.Topbar, Position=UDim2.new(1,-8,0,0), Size=UDim2.new(0,8,1,0), BorderSizePixel=0, Parent=sidebar})

	local tabHolder = mk("ScrollingFrame", {Name="TabHolder", BackgroundTransparency=1, Position=UDim2.new(0,0,0,6), Size=UDim2.new(1,0,1,-6), CanvasSize=UDim2.new(0,0,0,0), AutomaticCanvasSize=Enum.AutomaticSize.Y, ScrollBarThickness=0, BorderSizePixel=0, Parent=sidebar})
	pad(tabHolder, UDim.new(0,4), UDim.new(0,4), UDim.new(0,8), UDim.new(0,8))
	layout(tabHolder, 3)

	-- Divider sidebar
	mk("Frame", {BackgroundColor3=T.Border, Position=UDim2.new(0,sideW,0,43), Size=UDim2.new(0,1,1,-43), BorderSizePixel=0, Parent=main})

	-- Content area
	local contentArea = mk("Frame", {Name="Content", BackgroundTransparency=1, Position=UDim2.new(0,sideW+1,0,43), Size=UDim2.new(1,-sideW-1,1,-43), Parent=main})

	-- Open animation
	main.Size = UDim2.new(0, winW, 0, 0); main.BackgroundTransparency = 1
	tw(main, {Size=UDim2.new(0,winW,0,winH), BackgroundTransparency=0}, 0.5, Enum.EasingStyle.Exponential)

	-- Tab storage
	local tabs = {}
	local activeTab = nil

	-- Save/Load config
	local function SaveConfiguration()
		if not configEnabled or lib._destroyed then return end
		local data = {}
		for flag, elem in pairs(lib.Flags) do
			if elem.Type == "ColorPicker" then
				data[flag] = {R=elem.Color.R*255, G=elem.Color.G*255, B=elem.Color.B*255}
			elseif elem.CurrentValue ~= nil then
				data[flag] = elem.CurrentValue
			elseif elem.CurrentKeybind then
				data[flag] = elem.CurrentKeybind
			elseif elem.CurrentOption then
				data[flag] = elem.CurrentOption
			end
		end
		pcall(writefile, configFolderPath.."/"..configFile..".json", HttpService:JSONEncode(data))
	end
	lib._save = SaveConfiguration

	-- ГўвЂўВђГўвЂўВђГўвЂўВђ NOTIFY ГўвЂўВђГўвЂўВђГўвЂўВђ
	function lib:Notify(data)
		task.spawn(function()
			data = data or {}
			local card = mk("Frame", {BackgroundColor3=T.Surface, Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, ClipsDescendants=true, Parent=self.notifHolder})
			corner(card); stroke(card, T.Accent)

			local accent = T.Accent
			if data.Type == "Success" or (data.Content and data.Content:find("success")) then accent = T.Success; stroke(card, T.Success)
			elseif data.Type == "Warning" then accent = T.Warning; stroke(card, T.Warning)
			elseif data.Type == "Error" then accent = T.Error; stroke(card, T.Error) end

			mk("Frame", {BackgroundColor3=accent, Size=UDim2.new(0,3,1,0), BorderSizePixel=0, Parent=card})

			local inner = mk("Frame", {BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, Parent=card})
			pad(inner, UDim.new(0,12), UDim.new(0,12), UDim.new(0,16), UDim.new(0,12))
			layout(inner, 3)

			mk("TextLabel", {BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, Font=Enum.Font.GothamBold, Text=data.Title or "Notification", TextColor3=T.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, Parent=inner})
			mk("TextLabel", {BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, Font=Enum.Font.Gotham, Text=data.Content or "", TextColor3=T.TextDim, TextSize=13, TextWrapped=true, TextXAlignment=Enum.TextXAlignment.Left, Parent=inner})

			card.BackgroundTransparency = 1
			tw(card, {BackgroundTransparency=0}, 0.35)
			task.wait(data.Duration or 4)
			tw(card, {BackgroundTransparency=1}, 0.3)
			task.wait(0.35); card:Destroy()
		end)
	end

	-- ГўвЂўВђГўвЂўВђГўвЂўВђ CREATE TAB ГўвЂўВђГўвЂўВђГўвЂўВђ
	local Window = {}

	function Window:CreateTab(name, icon)
		local tabData = {name = name}

		-- Tab button in sidebar
		local btn = mk("TextButton", {Name=name, BackgroundColor3=T.Surface, BackgroundTransparency=1, Size=UDim2.new(1,0,0,32), Font=Enum.Font.Gotham, Text="  "..(name or "Tab"), TextColor3=T.TextDim, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, Parent=tabHolder})
		corner(btn, CRs)

		-- Tab page
		local page = mk("ScrollingFrame", {Name=name, BackgroundTransparency=1, Size=UDim2.new(1,0,1,0), CanvasSize=UDim2.new(0,0,0,0), AutomaticCanvasSize=Enum.AutomaticSize.Y, ScrollBarThickness=3, ScrollBarImageColor3=T.Accent, BorderSizePixel=0, Visible=false, Parent=contentArea})
		pad(page, UDim.new(0,12), UDim.new(0,12), UDim.new(0,14), UDim.new(0,14))
		layout(page, 6)

		tabData.btn = btn; tabData.page = page

		local function activate()
			for _,t in ipairs(tabs) do
				t.page.Visible = false
				tw(t.btn, {BackgroundTransparency=1, TextColor3=T.TextDim}, 0.2)
			end
			page.Visible = true
			tw(btn, {BackgroundTransparency=0, TextColor3=T.Text}, 0.2)
			activeTab = tabData
		end
		btn.MouseButton1Click:Connect(activate)
		table.insert(tabs, tabData)
		if #tabs == 1 then activate() end

		local Tab = {}
		local sectionDone = false

		-- ГўвЂўВђГўвЂўВђГўвЂўВђ SECTION ГўвЂўВђГўвЂўВђГўвЂўВђ
		function Tab:CreateSection(name)
			if sectionDone then mk("Frame", {BackgroundTransparency=1, Size=UDim2.new(1,0,0,6), Parent=page}) end
			local s = mk("TextLabel", {Name="Section", BackgroundTransparency=1, Size=UDim2.new(1,0,0,20), Font=Enum.Font.GothamBold, Text=string.upper(name or ""), TextColor3=T.TextFaint, TextSize=11, TextXAlignment=Enum.TextXAlignment.Left, Parent=page})
			sectionDone = true
			local api = {}; function api:Set(t) s.Text = string.upper(t) end; return api
		end

		-- ГўвЂўВђГўвЂўВђГўвЂўВђ DIVIDER ГўвЂўВђГўвЂўВђГўвЂўВђ
		function Tab:CreateDivider()
			local d = mk("Frame", {Name="Divider", BackgroundTransparency=1, Size=UDim2.new(1,0,0,9), Parent=page})
			mk("Frame", {BackgroundColor3=T.Border, BackgroundTransparency=0.5, AnchorPoint=Vector2.new(0,0.5), Position=UDim2.new(0,0,0.5,0), Size=UDim2.new(1,0,0,1), BorderSizePixel=0, Parent=d})
			local api = {}; function api:Set(v) d.Visible = v end; return api
		end

		-- ГўвЂўВђГўвЂўВђГўвЂўВђ BUTTON ГўвЂўВђГўвЂўВђГўвЂўВђ
		function Tab:CreateButton(cfg)
			cfg = cfg or {}
			local f = mk("Frame", {Name=cfg.Name or "Button", BackgroundColor3=T.Surface, Size=UDim2.new(1,0,0,38), Parent=page})
			corner(f, CRs); stroke(f)
			local title = mk("TextLabel", {BackgroundTransparency=1, Position=UDim2.new(0,12,0,0), Size=UDim2.new(1,-50,1,0), Font=Enum.Font.Gotham, Text=cfg.Name or "Button", TextColor3=T.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, Parent=f})
			mk("TextLabel", {BackgroundTransparency=1, AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,-12,0.5,0), Size=UDim2.new(0,20,0,20), Font=Enum.Font.GothamBold, Text="Гўв‚¬Вє", TextColor3=T.TextFaint, TextSize=18, Parent=f})
			local interact = mk("TextButton", {BackgroundTransparency=1, Size=UDim2.new(1,0,1,0), Text="", Parent=f})

			interact.MouseButton1Click:Connect(function()
				safecall(cfg.Callback)
				tw(f, {BackgroundColor3=T.AccentDark}, 0.1); task.wait(0.15); tw(f, {BackgroundColor3=T.Surface}, 0.2)
			end)
			f.MouseEnter:Connect(function() tw(f, {BackgroundColor3=T.SurfaceHover}, 0.15) end)
			f.MouseLeave:Connect(function() tw(f, {BackgroundColor3=T.Surface}, 0.15) end)

			local api = {}; function api:Set(t) title.Text = t; f.Name = t end; return api
		end

		-- ГўвЂўВђГўвЂўВђГўвЂўВђ TOGGLE ГўвЂўВђГўвЂўВђГўвЂўВђ
		function Tab:CreateToggle(cfg)
			cfg = cfg or {}; cfg.Type = "Toggle"
			cfg.CurrentValue = cfg.CurrentValue or false

			local f = mk("Frame", {Name=cfg.Name or "Toggle", BackgroundColor3=T.Surface, Size=UDim2.new(1,0,0,38), Parent=page})
			corner(f, CRs); stroke(f)
			mk("TextLabel", {BackgroundTransparency=1, Position=UDim2.new(0,12,0,0), Size=UDim2.new(1,-65,1,0), Font=Enum.Font.Gotham, Text=cfg.Name or "Toggle", TextColor3=T.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, Parent=f})

			local track = mk("Frame", {BackgroundColor3=cfg.CurrentValue and T.ToggleOn or T.ToggleOff, AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,-12,0.5,0), Size=UDim2.new(0,38,0,20), Parent=f})
			corner(track, UDim.new(1,0))
			local knob = mk("Frame", {BackgroundColor3=T.Text, AnchorPoint=Vector2.new(0,0.5), Position=cfg.CurrentValue and UDim2.new(1,-17,0.5,0) or UDim2.new(0,3,0.5,0), Size=UDim2.new(0,14,0,14), Parent=track})
			corner(knob, UDim.new(1,0))

			local function update()
				tw(track, {BackgroundColor3=cfg.CurrentValue and T.ToggleOn or T.ToggleOff}, 0.2)
				tw(knob, {Position=cfg.CurrentValue and UDim2.new(1,-17,0.5,0) or UDim2.new(0,3,0.5,0)}, 0.2, Enum.EasingStyle.Quart)
			end

			local interact = mk("TextButton", {BackgroundTransparency=1, Size=UDim2.new(1,0,1,0), Text="", Parent=f})
			interact.MouseButton1Click:Connect(function()
				cfg.CurrentValue = not cfg.CurrentValue; update(); safecall(cfg.Callback, cfg.CurrentValue); SaveConfiguration()
			end)
			f.MouseEnter:Connect(function() tw(f, {BackgroundColor3=T.SurfaceHover}, 0.15) end)
			f.MouseLeave:Connect(function() tw(f, {BackgroundColor3=T.Surface}, 0.15) end)

			function cfg:Set(v) cfg.CurrentValue = v; update(); safecall(cfg.Callback, v); SaveConfiguration() end
			if configEnabled and cfg.Flag then lib.Flags[cfg.Flag] = cfg end
			return cfg
		end

		-- ГўвЂўВђГўвЂўВђГўвЂўВђ SLIDER ГўвЂўВђГўвЂўВђГўвЂўВђ
		function Tab:CreateSlider(cfg)
			cfg = cfg or {}; cfg.Type = "Slider"
			local min, max = cfg.Range and cfg.Range[1] or 0, cfg.Range and cfg.Range[2] or 100
			local inc = cfg.Increment or 1
			cfg.CurrentValue = cfg.CurrentValue or min

			local f = mk("Frame", {Name=cfg.Name or "Slider", BackgroundColor3=T.Surface, Size=UDim2.new(1,0,0,50), Parent=page})
			corner(f, CRs); stroke(f)

			local lbl = mk("TextLabel", {BackgroundTransparency=1, Position=UDim2.new(0,12,0,2), Size=UDim2.new(1,-24,0,22), Font=Enum.Font.Gotham, TextColor3=T.Text, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, Parent=f})
			local valLbl = mk("TextLabel", {BackgroundTransparency=1, Position=UDim2.new(0,12,0,2), Size=UDim2.new(1,-24,0,22), Font=Enum.Font.GothamBold, TextColor3=T.Accent, TextSize=13, TextXAlignment=Enum.TextXAlignment.Right, Parent=f})

			local function updateText() lbl.Text = cfg.Name or "Slider"; valLbl.Text = tostring(cfg.CurrentValue)..(cfg.Suffix and " "..cfg.Suffix or "") end
			updateText()

			local trackBg = mk("Frame", {BackgroundColor3=T.SliderBg, Position=UDim2.new(0,12,0,32), Size=UDim2.new(1,-24,0,8), Parent=f})
			corner(trackBg, UDim.new(1,0))
			local fill = mk("Frame", {BackgroundColor3=T.SliderFill, Size=UDim2.new(math.clamp((cfg.CurrentValue-min)/(max-min),0,1),0,1,0), Parent=trackBg})
			corner(fill, UDim.new(1,0))

			local sliding = false
			local interact = mk("TextButton", {BackgroundTransparency=1, Size=UDim2.new(1,0,1,0), Text="", Parent=f})

			interact.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding=true end
			end)
			interact.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding=false end
			end)

			table.insert(lib._connections, UserInputService.InputChanged:Connect(function(input)
				if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					local rel = math.clamp((input.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
					local raw = min + (max - min) * rel
					local v = math.floor(raw / inc + 0.5) * inc
					v = math.clamp(v, min, max)
					if v ~= cfg.CurrentValue then cfg.CurrentValue = v; fill.Size = UDim2.new(rel,0,1,0); updateText(); safecall(cfg.Callback, v); SaveConfiguration() end
				end
			end))

			f.MouseEnter:Connect(function() tw(f, {BackgroundColor3=T.SurfaceHover}, 0.15) end)
			f.MouseLeave:Connect(function() tw(f, {BackgroundColor3=T.Surface}, 0.15) end)

			function cfg:Set(v) v=math.clamp(v,min,max); cfg.CurrentValue=v; local r=(v-min)/(max-min); fill.Size=UDim2.new(r,0,1,0); updateText(); safecall(cfg.Callback,v); SaveConfiguration() end
			if configEnabled and cfg.Flag then lib.Flags[cfg.Flag] = cfg end
			return cfg
		end

		-- ГўвЂўВђГўвЂўВђГўвЂўВђ DROPDOWN ГўвЂўВђГўвЂўВђГўвЂўВђ
		function Tab:CreateDropdown(cfg)
			cfg = cfg or {}; cfg.Type = "Dropdown"
			local opts = cfg.Options or {}
			if cfg.CurrentOption and type(cfg.CurrentOption) == "string" then cfg.CurrentOption = {cfg.CurrentOption} end
			cfg.CurrentOption = cfg.CurrentOption or {}
			if not cfg.MultipleOptions and #cfg.CurrentOption > 1 then cfg.CurrentOption = {cfg.CurrentOption[1]} end
			local opened = false

			local f = mk("Frame", {Name=cfg.Name or "Dropdown", BackgroundColor3=T.Surface, Size=UDim2.new(1,0,0,38), ClipsDescendants=true, Parent=page})
			corner(f, CRs); stroke(f)

			local displayText = #cfg.CurrentOption == 0 and "None" or (#cfg.CurrentOption == 1 and cfg.CurrentOption[1] or "Various")
			local title = mk("TextLabel", {BackgroundTransparency=1, Position=UDim2.new(0,12,0,0), Size=UDim2.new(1,-50,0,38), Font=Enum.Font.Gotham, Text=cfg.Name or "Dropdown", TextColor3=T.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, Parent=f})
			local sel = mk("TextLabel", {BackgroundTransparency=1, AnchorPoint=Vector2.new(1,0), Position=UDim2.new(1,-30,0,0), Size=UDim2.new(0.4,0,0,38), Font=Enum.Font.Gotham, Text=displayText, TextColor3=T.TextDim, TextSize=13, TextXAlignment=Enum.TextXAlignment.Right, Parent=f})
			local arrow = mk("TextLabel", {BackgroundTransparency=1, AnchorPoint=Vector2.new(1,0), Position=UDim2.new(1,-10,0,0), Size=UDim2.new(0,20,0,38), Font=Enum.Font.GothamBold, Text="ГўвЂ“Вё", TextColor3=T.TextFaint, TextSize=12, Parent=f})

			local listFrame = mk("Frame", {BackgroundTransparency=1, Position=UDim2.new(0,0,0,38), Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, Parent=f})
			pad(listFrame, UDim.new(0,4), UDim.new(0,6), UDim.new(0,6), UDim.new(0,6))
			layout(listFrame, 2)

			local function updateDisplay()
				if #cfg.CurrentOption == 0 then sel.Text = "None"
				elseif #cfg.CurrentOption == 1 then sel.Text = cfg.CurrentOption[1]
				else sel.Text = "Various" end
			end

			local function buildOpts()
				for _,c in ipairs(listFrame:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
				for _,opt in ipairs(opts) do
					local isSelected = table.find(cfg.CurrentOption, opt)
					local ob = mk("TextButton", {BackgroundColor3=isSelected and T.DropSelected or T.DropUnselected, Size=UDim2.new(1,0,0,30), Font=Enum.Font.Gotham, Text=opt, TextColor3=isSelected and T.Accent or T.TextDim, TextSize=13, Parent=listFrame})
					corner(ob, CRs)

					ob.MouseEnter:Connect(function() tw(ob, {BackgroundColor3=T.SurfaceHover, TextColor3=T.Text}, 0.1) end)
					ob.MouseLeave:Connect(function() tw(ob, {BackgroundColor3=table.find(cfg.CurrentOption,opt) and T.DropSelected or T.DropUnselected, TextColor3=table.find(cfg.CurrentOption,opt) and T.Accent or T.TextDim}, 0.1) end)

					ob.MouseButton1Click:Connect(function()
						if cfg.MultipleOptions then
							local idx = table.find(cfg.CurrentOption, opt)
							if idx then table.remove(cfg.CurrentOption, idx) else table.insert(cfg.CurrentOption, opt) end
						else
							cfg.CurrentOption = {opt}
							opened = false; tw(f, {Size=UDim2.new(1,0,0,38)}, 0.25); tw(arrow, {Rotation=0}, 0.2)
						end
						updateDisplay(); buildOpts(); safecall(cfg.Callback, cfg.CurrentOption); SaveConfiguration()
					end)
				end
			end
			buildOpts()

			local headerBtn = mk("TextButton", {BackgroundTransparency=1, Size=UDim2.new(1,0,0,38), Text="", Parent=f})
			headerBtn.MouseButton1Click:Connect(function()
				opened = not opened
				if opened then
					tw(f, {Size=UDim2.new(1,0,0, 38+12+#opts*32)}, 0.3); tw(arrow, {Rotation=90}, 0.2)
				else
					tw(f, {Size=UDim2.new(1,0,0,38)}, 0.25); tw(arrow, {Rotation=0}, 0.2)
				end
			end)

			f.MouseEnter:Connect(function() if not opened then tw(f, {BackgroundColor3=T.SurfaceHover}, 0.15) end end)
			f.MouseLeave:Connect(function() tw(f, {BackgroundColor3=T.Surface}, 0.15) end)

			function cfg:Set(v) if type(v)=="string" then v={v} end; cfg.CurrentOption=v; updateDisplay(); buildOpts(); safecall(cfg.Callback,v); SaveConfiguration() end
			function cfg:Refresh(newOpts) opts=newOpts; cfg.Options=newOpts; buildOpts() end
			if configEnabled and cfg.Flag then lib.Flags[cfg.Flag] = cfg end
			return cfg
		end

		-- ГўвЂўВђГўвЂўВђГўвЂўВђ INPUT ГўвЂўВђГўвЂўВђГўвЂўВђ
		function Tab:CreateInput(cfg)
			cfg = cfg or {}; cfg.Type = "Input"
			cfg.CurrentValue = cfg.CurrentValue or ""

			local f = mk("Frame", {Name=cfg.Name or "Input", BackgroundColor3=T.Surface, Size=UDim2.new(1,0,0,38), Parent=page})
			corner(f, CRs); stroke(f)
			mk("TextLabel", {BackgroundTransparency=1, Position=UDim2.new(0,12,0,0), Size=UDim2.new(0.48,0,1,0), Font=Enum.Font.Gotham, Text=cfg.Name or "Input", TextColor3=T.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, Parent=f})

