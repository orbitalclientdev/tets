            function Section:CreateBind(bSettings)
                bSettings = Kwargify({Name = "Keybind", Description = nil, CurrentBind = "E", HoldToInteract = false, Flag = nil, Callback = function() end, OnChangedCallback = function() end}, bSettings or {})
                local height = bSettings.Description and 52 or 36
                local bind = MakeGlassFrame({Name = bSettings.Name, Size = UDim2.new(1, 0, 0, height), BgTransparency = 0.5, Parent = sectionContainer})
                MakeText({Text = bSettings.Name, Size = UDim2.new(1, -100, 0, 16), Position = UDim2.new(0, 12, 0, bSettings.Description and 6 or 10), Font = Enum.Font.GothamSemibold, TextSize = 13, Parent = bind, ZIndex = 3})
                if bSettings.Description then MakeText({Text = bSettings.Description, Size = UDim2.new(1, -100, 0, 14), Position = UDim2.new(0, 12, 0, 24), Font = Enum.Font.Gotham, TextSize = 11, TextColor = COLORS.textMuted, Parent = bind, ZIndex = 3}) end

                local bindBox = Instance.new("TextBox")
                bindBox.Size = UDim2.new(0, 60, 0, 24)
                bindBox.Position = UDim2.new(1, -12, 0.5, 0)
                bindBox.AnchorPoint = Vector2.new(1, 0.5)
                bindBox.BackgroundColor3 = COLORS.bgLight
                bindBox.BackgroundTransparency = 0.5
                bindBox.BorderSizePixel = 0
                bindBox.Font = Enum.Font.GothamBold
                bindBox.TextSize = 12
                bindBox.TextColor3 = accentColor
                bindBox.Text = bSettings.CurrentBind
                bindBox.ClearTextOnFocus = true
                bindBox.ZIndex = 4
                bindBox.Parent = bind
                local bbCorner = Instance.new("UICorner"); bbCorner.CornerRadius = UDim.new(0, 6); bbCorner.Parent = bindBox
                local bbStroke = Instance.new("UIStroke"); bbStroke.Color = COLORS.border; bbStroke.Transparency = 0.5; bbStroke.Parent = bindBox

                local BindV = {CurrentBind = bSettings.CurrentBind, Active = false, Type = "Keybind", Settings = bSettings}
                local checking = false

                bindBox.Focused:Connect(function() checking = true; bindBox.Text = "..." end)
                bindBox.FocusLost:Connect(function() checking = false; if bindBox.Text == "..." or bindBox.Text == "" then bindBox.Text = BindV.CurrentBind end end)

                track(UserInputService.InputBegan:Connect(function(input, processed)
                    if checking then
                        if input.KeyCode ~= Enum.KeyCode.Unknown then
                            local keyName = input.KeyCode.Name
                            BindV.CurrentBind = keyName
                            bSettings.CurrentBind = keyName
                            bindBox.Text = keyName
                            bindBox:ReleaseFocus()
                            pcall(bSettings.OnChangedCallback, keyName)
                        end
                    elseif BindV.CurrentBind and not processed then
                        local ok, keyEnum = pcall(function() return Enum.KeyCode[BindV.CurrentBind] end)
                        if ok and input.KeyCode == keyEnum then
                            if not bSettings.HoldToInteract then
                                BindV.Active = not BindV.Active
                                SafeCall(nil, bSettings.Name, bSettings.Callback, BindV.Active)
                            else
                                SafeCall(nil, bSettings.Name, bSettings.Callback, true)
                                local conn; conn = input.Changed:Connect(function(prop)
                                    if prop == "UserInputState" then conn:Disconnect(); SafeCall(nil, bSettings.Name, bSettings.Callback, false) end
                                end)
                            end
                        end
                    end
                end))

                bind.MouseEnter:Connect(function() tween(bind.UIStroke, {Color = COLORS.borderHover}, nil, TWEENINFO_FAST) end)
                bind.MouseLeave:Connect(function() tween(bind.UIStroke, {Color = COLORS.border}, nil, TWEENINFO_FAST) end)

                function BindV:Set(newBind) BindV.CurrentBind = newBind; bSettings.CurrentBind = newBind; bindBox.Text = newBind end
                function BindV:Destroy() bind:Destroy() end
                Section.CreateKeybind = Section.CreateBind -- alias
                if bSettings.Flag then Library.Flags[bSettings.Flag] = BindV; Library.Options[bSettings.Flag] = BindV end
                return BindV
            end
            Section.CreateKeybind = Section.CreateBind

