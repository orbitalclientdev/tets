            sectionContainer.AutomaticSize = Enum.AutomaticSize.Y
            sectionContainer.BackgroundTransparency = 1
            sectionContainer.BorderSizePixel = 0
            sectionContainer.Parent = tabPage

            local secLayout = Instance.new("UIListLayout")
            secLayout.SortOrder = Enum.SortOrder.LayoutOrder
            secLayout.Padding = UDim.new(0, 5)
            secLayout.Parent = sectionContainer

            function Section:Set(newName) sectionLabel.Text = string.upper(newName) end
            function Section:Destroy() sectionLabel:Destroy() sectionContainer:Destroy() end

            -- Helper: safe callback
            local function SafeCall(element, elementName, callback, ...)
                local ok, err = pcall(callback, ...)
                if not ok then
                    warn("5BLib | " .. elementName .. " Error: " .. tostring(err))
                    if element then
                        tween(element, {BackgroundColor3 = COLORS.danger, BackgroundTransparency = 0}, nil, TWEENINFO)
                        task.wait(0.5)
                        tween(element, {BackgroundColor3 = COLORS.bgElement, BackgroundTransparency = 0.5}, nil, TWEENINFO)
                    end
                end
            end

            -- DIVIDER
            function Section:CreateDivider()
                local div = Instance.new("Frame")
                div.Name = "Divider"
                div.Size = UDim2.new(1, 0, 0, 12)
                div.BackgroundTransparency = 1
                div.Parent = sectionContainer
                local line = Instance.new("Frame")
                line.Size = UDim2.new(1, 0, 0, 1)
                line.Position = UDim2.new(0, 0, 0.5, 0)
                line.AnchorPoint = Vector2.new(0, 0.5)
                line.BackgroundColor3 = COLORS.border
                line.BackgroundTransparency = 0.5
                line.BorderSizePixel = 0
                line.Parent = div
                return {Visible = function(_, v) div.Visible = v end}
            end

            -- BUTTON
            function Section:CreateButton(btnSettings)
                btnSettings = Kwargify({Name = "Button", Description = nil, Callback = function() end}, btnSettings or {})
                local height = btnSettings.Description and 52 or 36
                local btn, btnStroke = MakeGlassFrame({Name = btnSettings.Name, Size = UDim2.new(1, 0, 0, height), BgTransparency = 0.5, Parent = sectionContainer})
                local titleT = MakeText({Text = btnSettings.Name, Size = UDim2.new(1, -20, 0, 16), Position = UDim2.new(0, 12, 0, btnSettings.Description and 8 or 10), Font = Enum.Font.GothamSemibold, TextSize = 13, Parent = btn, ZIndex = 3, TextTransparency = 1})
                tween(titleT, {TextTransparency = 0}, nil, TWEENINFO_SMOOTH)
                local descT
                if btnSettings.Description then
                    descT = MakeText({Text = btnSettings.Description, Size = UDim2.new(1, -20, 0, 14), Position = UDim2.new(0, 12, 0, 28), Font = Enum.Font.Gotham, TextSize = 11, TextColor = COLORS.textMuted, Parent = btn, ZIndex = 3, TextTransparency = 1})
                    tween(descT, {TextTransparency = 0}, nil, TWEENINFO_SMOOTH)
                end
                local interact = MakeInteract(btn)
                interact.MouseButton1Click:Connect(function() SafeCall(btn, btnSettings.Name, btnSettings.Callback) tween(btnStroke, {Color = COLORS.borderActive}) task.wait(0.2) tween(btnStroke, {Color = COLORS.border}) end)
                btn.MouseEnter:Connect(function() tween(btnStroke, {Color = COLORS.borderHover}, nil, TWEENINFO_FAST) end)
                btn.MouseLeave:Connect(function() tween(btnStroke, {Color = COLORS.border}, nil, TWEENINFO_FAST) end)
                local BtnV = {Settings = btnSettings}
                function BtnV:Set(s) s = Kwargify(btnSettings, s or {}) btnSettings = s; titleT.Text = s.Name; if descT and s.Description then descT.Text = s.Description end end
                function BtnV:Destroy() btn:Destroy() end
                return BtnV
            end

            -- LABEL (3 styles: 1=normal, 2=info, 3=warning)
            function Section:CreateLabel(labelSettings)
                labelSettings = Kwargify({Text = "Label", Style = 1}, labelSettings or {})
                local styleColors = {[1] = COLORS.text, [2] = COLORS.info, [3] = COLORS.warn}
                local styleBg = {[1] = 1, [2] = 0.85, [3] = 0.85}
                local styleBgColor = {[1] = COLORS.bgElement, [2] = Color3.fromRGB(30, 45, 70), [3] = Color3.fromRGB(60, 50, 25)}
                local lbl, lblStroke = MakeGlassFrame({Name = "Label", Size = UDim2.new(1, 0, 0, 32), BgColor = styleBgColor[labelSettings.Style], BgTransparency = styleBg[labelSettings.Style], Parent = sectionContainer})
                if labelSettings.Style > 1 then
                    local accentL = Instance.new("Frame"); accentL.Size = UDim2.new(0, 3, 1, -8); accentL.Position = UDim2.new(0, 4, 0, 4); accentL.BackgroundColor3 = styleColors[labelSettings.Style]; accentL.BorderSizePixel = 0; accentL.ZIndex = 3; accentL.Parent = lbl
                    local ac = Instance.new("UICorner"); ac.CornerRadius = UDim.new(0, 2); ac.Parent = accentL
                end
