			local lbl = mk("TextLabel", {BackgroundTransparency=1, Position=UDim2.new(0,12,0,0), Size=UDim2.new(1,-24,1,0), Font=Enum.Font.Gotham, Text=text or "", TextColor3=T.Text, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, TextWrapped=true, Parent=f})
