		-- ГўвЂўВђГўвЂўВђГўвЂўВђ PARAGRAPH ГўвЂўВђГўвЂўВђГўвЂўВђ
		function Tab:CreateParagraph(cfg)
			cfg = cfg or {}
			local f = mk("Frame", {Name="Paragraph", BackgroundColor3=T.Surface, Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, Parent=page})
			corner(f, CRs); stroke(f)
			local inner = mk("Frame", {BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, Parent=f})
