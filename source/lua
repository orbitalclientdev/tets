			local cont = mk("TextLabel", {BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, Font=Enum.Font.Gotham, Text=cfg.Content or "", TextColor3=T.TextDim, TextSize=13, TextWrapped=true, TextXAlignment=Enum.TextXAlignment.Left, Parent=inner})
