function Library:Notification(data)
    task.spawn(function()
        data = Kwargify({
            Title = "Notification",
            Content = "",
            Icon = "info",
            Duration = nil,
            Type = "Info", -- Info, Success, Warning, Error
        }, data or {})

        local typeColors = {
            Info = COLORS.info,
            Success = COLORS.success,
            Warning = COLORS.warn,
            Error = COLORS.danger,
        }
        local accentColor = typeColors[data.Type] or COLORS.info

        local notifFrame = MakeGlassFrame({
            Name = data.Title,
            Size = UDim2.new(1, 0, 0, 0),
            BgColor = COLORS.bg,
            BgTransparency = 0.35,
            BorderTransparency = 0.85,
            Parent = self._notifContainer,
        })
        notifFrame.ClipsDescendants = true

        -- Accent line left
        local accentLine = Instance.new("Frame")
        accentLine.Name = "Accent"
        accentLine.Size = UDim2.new(0, 3, 1, -8)
        accentLine.Position = UDim2.new(0, 4, 0, 4)
        accentLine.BackgroundColor3 = accentColor
        accentLine.BorderSizePixel = 0
        accentLine.ZIndex = 3
        accentLine.Parent = notifFrame
        local accentCorner = Instance.new("UICorner")
        accentCorner.CornerRadius = UDim.new(0, 2)
        accentCorner.Parent = accentLine

        local icon = MakeIcon({
            Image = data.Icon,
            Size = UDim2.new(0, 22, 0, 22),
            Position = UDim2.new(0, 16, 0, 14),
            AnchorPoint = Vector2.new(0, 0),
            ImageColor = accentColor,
            ImageTransparency = 1,
            Parent = notifFrame,
            ZIndex = 3,
        })

        local title = MakeText({
            Name = "Title",
            Text = data.Title,
            Size = UDim2.new(1, -50, 0, 18),
            Position = UDim2.new(0, 46, 0, 8),
            Font = Enum.Font.GothamBold,
            TextSize = 13,
            TextColor = COLORS.text,
            TextTransparency = 1,
            Parent = notifFrame,
            ZIndex = 3,
        })

        local desc = MakeText({
            Name = "Desc",
            Text = data.Content,
            Size = UDim2.new(1, -50, 0, 1000),
            Position = UDim2.new(0, 46, 0, 28),
            Font = Enum.Font.Gotham,
            TextSize = 12,
            TextColor = COLORS.textDim,
            TextTransparency = 1,
            TextWrapped = true,
            Parent = notifFrame,
            ZIndex = 3,
        })

        task.wait()
        local textHeight = desc.TextBounds.Y
        desc.Size = UDim2.new(1, -50, 0, textHeight)
        local totalHeight = 38 + textHeight

        -- Animate in
        tween(notifFrame, {Size = UDim2.new(1, 0, 0, totalHeight)}, nil, TWEENINFO_SLOW)
        task.wait(0.15)
        tween(notifFrame, {BackgroundTransparency = 0.35})
        tween(title, {TextTransparency = 0})
        task.wait(0.05)
        tween(icon, {ImageTransparency = 0})
        tween(desc, {TextTransparency = 0.3})

        local waitTime = data.Duration or math.clamp(#data.Content * 0.08 + 2.5, 3, 10)
        task.wait(waitTime)

        -- Animate out
        tween(notifFrame, {BackgroundTransparency = 1}, nil, TWEENINFO)
        tween(title, {TextTransparency = 1}, nil, TWEENINFO)
        tween(desc, {TextTransparency = 1}, nil, TWEENINFO)
        tween(icon, {ImageTransparency = 1}, nil, TWEENINFO)
        tween(notifFrame.UIStroke, {Transparency = 1}, nil, TWEENINFO)
        task.wait(0.3)
        tween(notifFrame, {Size = UDim2.new(1, 0, 0, 0)}, nil, TWEENINFO_SLOW)
        task.wait(0.5)
        notifFrame:Destroy()
    end)
end

local function Draggable(dragHandle, window)
    local dragging, dragInput, mousePos, framePos

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            mousePos = input.Position
            framePos = window.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    dragHandle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - mousePos
            tween(window, {Position = UDim2.new(
                framePos.X.Scale, framePos.X.Offset + delta.X,
                framePos.Y.Scale, framePos.Y.Offset + delta.Y
            )}, nil, TweenInfo.new(0.25, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out))
        end
    end)
end

