        function Tab:CreateSection(name)
            name = name or "Section"
            local Section = {Name = name}

            local sectionLabel = MakeText({
                Text = string.upper(name),
                Size = UDim2.new(1, 0, 0, 22),
                Font = Enum.Font.GothamBold,
                TextSize = 10,
                TextColor = COLORS.textMuted,
