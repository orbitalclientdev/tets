		-- ГўвЂўВђГўвЂўВђГўвЂўВђ KEYBIND ГўвЂўВђГўвЂўВђГўвЂўВђ
		function Tab:CreateKeybind(cfg)
			cfg = cfg or {}; cfg.Type = "Keybind"
			cfg.CurrentKeybind = cfg.CurrentKeybind or "Unknown"
			local listening = false

			local f = mk("Frame", {Name=cfg.Name or "Keybind", BackgroundColor3=T.Surface, Size=UDim2.new(1,0,0,38), Parent=page})
			corner(f, CRs); stroke(f)
			mk("TextLabel", {BackgroundTransparency=1, Position=UDim2.new(0,12,0,0), Size=UDim2.new(1,-85,1,0), Font=Enum.Font.Gotham, Text=cfg.Name or "Keybind", TextColor3=T.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, Parent=f})

			local keyBtn = mk("TextButton", {BackgroundColor3=T.InputBg, AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,-8,0.5,0), Size=UDim2.new(0,65,0,26), Font=Enum.Font.GothamBold, Text=cfg.CurrentKeybind, TextColor3=T.Accent, TextSize=12, Parent=f})
			corner(keyBtn, CRs); stroke(keyBtn, T.Border)

			keyBtn.MouseButton1Click:Connect(function()
				listening=true; keyBtn.Text="..."; tw(keyBtn, {TextColor3=T.Warning}, 0.15)
			end)

			table.insert(lib._connections, UserInputService.InputBegan:Connect(function(input, gpe)
				if listening and input.UserInputType == Enum.UserInputType.Keyboard then
					local kn = input.KeyCode.Name; cfg.CurrentKeybind = kn; keyBtn.Text = kn
					tw(keyBtn, {TextColor3=T.Accent}, 0.15); listening = false
					if cfg.CallOnChange then safecall(cfg.Callback, kn) end; SaveConfiguration()
				elseif not gpe and not listening and cfg.CurrentKeybind and input.KeyCode == Enum.KeyCode[cfg.CurrentKeybind] then
					if cfg.HoldToInteract then
						local held = true
						local c; c = input.Changed:Connect(function(p) if p=="UserInputState" then c:Disconnect(); held=false end end)
						task.wait(0.25)
						if held then local loop; loop = RunService.Stepped:Connect(function() if not held then safecall(cfg.Callback,false); loop:Disconnect() else safecall(cfg.Callback,true) end end) end
					else
						safecall(cfg.Callback, cfg.CurrentKeybind)
					end
				end
			end))

			f.MouseEnter:Connect(function() tw(f, {BackgroundColor3=T.SurfaceHover}, 0.15) end)
			f.MouseLeave:Connect(function() tw(f, {BackgroundColor3=T.Surface}, 0.15) end)

			function cfg:Set(k) cfg.CurrentKeybind=k; keyBtn.Text=k; if cfg.CallOnChange then safecall(cfg.Callback,k) end; SaveConfiguration() end
			if configEnabled and cfg.Flag then lib.Flags[cfg.Flag] = cfg end
			return cfg
		end

		-- ГўвЂўВђГўвЂўВђГўвЂўВђ LABEL ГўвЂўВђГўвЂўВђГўвЂўВђ
