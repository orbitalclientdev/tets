                inputBox.ClearTextOnFocus = false
                inputBox.ZIndex = 4
                inputBox.Parent = inp
                local ibCorner = Instance.new("UICorner"); ibCorner.CornerRadius = UDim.new(0, 6); ibCorner.Parent = inputBox
                local ibStroke = Instance.new("UIStroke"); ibStroke.Color = COLORS.border; ibStroke.Transparency = 0.5; ibStroke.Parent = inputBox
                local ibPad = Instance.new("UIPadding"); ibPad.PaddingLeft = UDim.new(0, 8); ibPad.PaddingRight = UDim.new(0, 8); ibPad.Parent = inputBox

                local InpV = {CurrentValue = iSettings.CurrentValue, Type = "Input", Settings = iSettings}

                if iSettings.Numeric then
                    inputBox:GetPropertyChangedSignal("Text"):Connect(function()
                        local t = inputBox.Text
                        if not tonumber(t) and t ~= "" and t ~= "." and t ~= "-" then inputBox.Text = t:match("[%-0-9.]*") or "" end
                    end)
                end
                if iSettings.MaxCharacters then
                    inputBox:GetPropertyChangedSignal("Text"):Connect(function()
                        if #inputBox.Text > iSettings.MaxCharacters then inputBox.Text = inputBox.Text:sub(1, iSettings.MaxCharacters) end
                    end)
                end

                inputBox.FocusLost:Connect(function(enterPressed)
                    if iSettings.Enter and not enterPressed then return end
                    InpV.CurrentValue = inputBox.Text
                    SafeCall(inp, iSettings.Name, iSettings.Callback, inputBox.Text)
                    if iSettings.RemoveTextAfterFocusLost then inputBox.Text = "" end
                end)

                if not iSettings.Enter then
                    inputBox:GetPropertyChangedSignal("Text"):Connect(function()
                        InpV.CurrentValue = inputBox.Text
                        SafeCall(nil, iSettings.Name, iSettings.Callback, inputBox.Text)
                    end)
                end

                inp.MouseEnter:Connect(function() tween(inp.UIStroke, {Color = COLORS.borderHover}, nil, TWEENINFO_FAST) end)
                inp.MouseLeave:Connect(function() tween(inp.UIStroke, {Color = COLORS.border}, nil, TWEENINFO_FAST) end)

